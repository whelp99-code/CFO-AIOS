{
  "name": "cfo-aios",
  "version": "0.1.0",
  "private": true,
  "description": "CFO-AIOS monorepo",
  "scripts": {
    "dev": "turbo run dev",
    "dev:api": "turbo run dev --filter=@cfo/api",
    "dev:web": "turbo run dev --filter=@cfo/web",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "setup": "pnpm install && pnpm db:generate",
    "db:generate": "pnpm --filter @cfo/api db:generate",
    "db:push": "pnpm --filter @cfo/api db:push",
    "db:migrate": "pnpm --filter @cfo/api exec prisma migrate dev",
    "local:sync": "bash scripts/local-sync.sh"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.15.0",
  "devDependencies": {
    "turbo": "^2.5.4"
  }
}
