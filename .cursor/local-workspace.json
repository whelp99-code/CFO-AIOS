{
  "$schema": "https://cursor.com/schemas/local-workspace.v1.json",
  "primary": true,
  "path": "/Users/jmpark/Documents/Playground/CFO-AI",
  "remote": {
    "name": "origin",
    "url": "https://github.com/whelp99-code/cfo-aios.git",
    "branch": "main"
  },
  "cloudMirror": {
    "enabled": true,
    "description": "Cloud Agent VM mirrors this repo; local path is the canonical workspace."
  },
  "services": {
    "api": {
      "cwd": "apps/api",
      "port": 4000,
      "url": "http://localhost:4000/api"
    },
    "web": {
      "cwd": "apps/web",
      "port": 5555,
      "url": "http://localhost:5555"
    }
  }
}
