{
  "name": "@cfo/api",
  "version": "0.1.0",
  "private": true,
  "description": "CFO-AIOS NestJS API (Prisma, Notion sync, Popbill, CODEF stubs)",
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch",
    "start": "node dist/main.js",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "notion:sync": "tsx scripts/migrate-notion-to-cfo.ts",
    "notion:import-csv": "tsx scripts/import-csv-to-prisma.ts"
  },
  "dependencies": {
    "@nestjs/common": "^10.3.0",
    "@nestjs/core": "^10.3.0",
    "@nestjs/platform-express": "^10.3.0",
    "@prisma/client": "^6.19.3",
    "@notionhq/client": "^2.2.15",
    "popbill": "^1.8.0",
    "pg": "^8.16.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.3.0",
    "@types/node": "^20.10.0",
    "prisma": "^6.19.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
