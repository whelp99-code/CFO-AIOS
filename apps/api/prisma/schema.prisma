generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// 프로젝트
model Project {
  id        String   @id @default(cuid())
  notionId  String?  @unique
  name      String
  status    String   @default("진행전")
  client    String?
  startDate DateTime?
  endDate   DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  invoices  Invoice[]
  expenses  Expense[]
  cashflows Cashflow[]
}

// 미수금/입금관리
model Invoice {
  id            String    @id @default(cuid())
  notionId      String?   @unique
  projectId     String?
  project       Project?  @relation(fields: [projectId], references: [id])
  
  buyer         String?
  amount        Float?
  depositAmount Float?
  depositStatus String    @default("미수")
  depositDate   DateTime?
  memo          String?
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

// 매입/비용
model Expense {
  id            String    @id @default(cuid())
  notionId      String?   @unique
  projectId     String?
  project       Project?  @relation(fields: [projectId], references: [id])
  
  expenseName   String
  supplier      String?
  category      String    @default("기타")
  date          DateTime?
  supplyAmount  Float?
  vat           Float?
  total         Float?
  paymentMethod String?
  proofType     String?
  isPaid        Boolean   @default(false)
  attachment    String?
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

// 자금흐름
model Cashflow {
  id            String    @id @default(cuid())
  notionId      String?   @unique
  projectId     String?
  project       Project?  @relation(fields: [projectId], references: [id])
  
  counterparty  String
  amount        Float
  type          String
  outAccount    String?
  inAccount     String?
  date          DateTime?
  memo          String?
  cashChange    Float?
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

// 구독 추적
model Subscription {
  id                String   @id @default(cuid())
  name              String
  vendor            String?
  amount            Float
  currency          String   @default("KRW")
  cycle             String   @default("monthly")
  category          String?
  nextBillingDate   DateTime
  paymentMethod     String?
  isActive          Boolean  @default(true)
  notifyDaysBefore  Int      @default(7)
  memo              String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}
